{
  "cases": [
    {
      "case_id": "research_session_create_missing_objective",
      "request_fixture": "merlin.research.manager.session.create.request.json",
      "setup": "research_manager_default",
      "payload": {
        "objective": "   "
      },
      "expected_status": 422,
      "expected_error": {
        "code": "VALIDATION_ERROR",
        "message": "payload.objective is required",
        "retryable": false
      }
    },
    {
      "case_id": "research_session_create_invalid_constraints_type",
      "request_fixture": "merlin.research.manager.session.create.request.json",
      "setup": "research_manager_default",
      "payload": {
        "objective": "Valid objective",
        "constraints": "repo-local-only"
      },
      "expected_status": 422,
      "expected_error": {
        "code": "VALIDATION_ERROR",
        "message": "payload.constraints must be an array when provided",
        "retryable": false
      }
    },
