{
    "schemaName":  "PluginManifest",
    "schemaVersion":  "1.0.0",
    "name":  "session_streamer",
    "version":  "2.0.0",
    "description":  "Stream Merlin session events to Maelstrom IPC",
    "entry":  "plugin.py",
    "type":  "plugin",
    "capabilities":  [
                         {
                             "schemaName":  "Capability",
                             "schemaVersion":  "1.0.0",
                             "name":  "merlin.session.stream",
                             "version":  "0.1.0"
                         }
                     ],
    "python_dependencies":  [
                                {
                                    "module":  "core.integrations.maelstrom_ipc",
                                    "package":  "merlin-assistant",
                                    "extra":  "plugins-all"
                                }
                            ],
    "extensions":  {
                       "aas":  {
                                   "hive":  "merlin",
                                   "visibility":  "global",
                                   "exports":  [
                                                   "merlin.session.stream"
                                               ],
                                   "kernel":  "merlin"
                               }
                   },
    "python_version":  "\u003e=3.12"
}
