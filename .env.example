# Merlin API server
MERLIN_API_HOST=0.0.0.0
MERLIN_API_PORT=8000
MERLIN_ALLOWED_ORIGINS=*
MERLIN_API_KEY=merlin-secret-key
# Optional rotated keys (comma-separated)
MERLIN_API_KEYS=
# Optional hot-reload key file (comma/newline-separated keys)
MERLIN_API_KEY_ROTATION_FILE=
# Strict mode disables fallback default key when no configured key exists
MERLIN_API_KEY_ROTATION_STRICT=false
MERLIN_HTTP_KEEP_ALIVE_TIMEOUT_S=15
MERLIN_HTTP_GRACEFUL_SHUTDOWN_TIMEOUT_S=30
# Optional cap for concurrent active requests (blank disables cap)
MERLIN_HTTP_LIMIT_CONCURRENCY=
# Merlin developmental maturity policy labels stamped in operation/routing metadata.
MERLIN_MATURITY_TIER=M0
MERLIN_MATURITY_POLICY_VERSION=mdmm-2026-02-22
# DiscoveryEngine live automation flag (default true; set false to force stubbed live capabilities).
ALLOW_LIVE_AUTOMATION=true
# Optional per-tier operation allowlists (JSON object). Supports "*" wildcard.
# Example: {"M0":["assistant.chat.request","merlin.tasks.list"],"M1":"*","M2":"*","M3":"*","M4":"*"}
MERLIN_MATURITY_OPERATION_ALLOWLISTS=
# Set false in production to avoid reload overhead.
MERLIN_API_RELOAD=true

# Chat history
MERLIN_CHAT_HISTORY_DIR=merlin_chat_history
# Research manager retention/archival
MERLIN_RESEARCH_SESSION_TTL_DAYS=90
MERLIN_RESEARCH_AUTO_ARCHIVE_ENABLED=true

# LLM backends
# Backend selection: "lmstudio", "ollama", "openai", "huggingface", "parallel", "adaptive", "dms"
LLM_BACKEND=lmstudio

# Parallel/Adaptive LLM strategy: "voting", "routing", "cascade", "consensus", "auto"
PARALLEL_STRATEGY=auto

# Adaptive LLM settings
LEARNING_MODE=enabled
MIN_LEARNING_SAMPLES=5
# Cache repeated system prompts for providers that use flattened prompt text.
MERLIN_SYSTEM_PROMPT_CACHE_ENABLED=true
MERLIN_SYSTEM_PROMPT_CACHE_MAX_ENTRIES=128

# LM Studio configuration
LM_STUDIO_URL=http://127.0.0.1:1234/v1/chat/completions

# Ollama configuration (local LLM hosting)
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODELS=["llama3.2", "mistral", "nomic", "glm4"]
OLLAMA_TIMEOUT=30

# OpenAI configuration
OPENAI_API_KEY=
OPENAI_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-3.5-turbo

# DMS (Dynamic Memory Sparsification) endpoint configuration
# Keep disabled unless you have a running OpenAI-compatible DMS endpoint.
DMS_ENABLED=false
DMS_URL=http://localhost:8002/v1/chat/completions
DMS_MODEL=nvidia/Qwen3-8B-DMS-8x
DMS_API_KEY=
# Prefer DMS for long prompts or high-complexity reasoning tasks.
DMS_MIN_PROMPT_CHARS=6000
# Optional token-aware threshold used when MERLIN_PROMPT_BUCKET_TOKEN_AWARE=true.
DMS_MIN_PROMPT_TOKENS=1500
# Comma-separated task types supported by DMS preference logic.
DMS_TASK_TYPES=analysis,code,planning
# Optional token-aware prompt bucketing for routing and timeout profiles.
MERLIN_PROMPT_BUCKET_TOKEN_AWARE=false
# Prompt-size timeout profiles (seconds) used when timeout is not explicitly provided.
MERLIN_MODEL_TIMEOUT_SHORT_S=15
MERLIN_MODEL_TIMEOUT_MEDIUM_S=30
MERLIN_MODEL_TIMEOUT_LONG_S=60
# Optional per-backend timeout overrides:
# backend.bucket=seconds where bucket is short|medium|long
# Example: dms.short=25,dms.medium=45,dms.long=90,openai.long=75
MERLIN_MODEL_TIMEOUT_MATRIX=
# Prompt token safety/truncation controls (applies before backend dispatch).
MERLIN_PROMPT_TOKEN_SOFT_LIMIT=8192
MERLIN_PROMPT_TOKEN_TRUNCATE_TARGET=7168
MERLIN_PROMPT_NEAR_LIMIT_RATIO=0.9
# Optional transient retry policy for backend HTTP calls.
MERLIN_LLM_RETRY_ENABLED=false
MERLIN_LLM_RETRY_MAX_ATTEMPTS=2
MERLIN_LLM_RETRY_INITIAL_BACKOFF_MS=100
MERLIN_LLM_RETRY_MAX_BACKOFF_MS=1000
MERLIN_LLM_RETRY_JITTER_RATIO=0.2
MERLIN_LLM_RETRY_BUDGET_MS=1500
# Optional ultra-fast lane for short prompts in adaptive/parallel routers.
MERLIN_ROUTER_FAST_SHORT_LANE_ENABLED=true
MERLIN_ROUTER_FAST_SHORT_CHAR_MAX=160
# Optional DMS cold-start warmup probe.
DMS_WARMUP_ENABLED=false
DMS_WARMUP_TIMEOUT_S=5
DMS_WARMUP_PROMPT=Merlin DMS warmup probe.
# Optional A/B control between DMS-first routing and existing routing.
DMS_AB_ENABLED=false
DMS_AB_DMS_PERCENTAGE=50
# Adaptive DMS error-budget controls (temporarily suppress DMS after high failure rate).
DMS_ERROR_BUDGET_ENABLED=true
DMS_ERROR_BUDGET_WINDOW=20
DMS_ERROR_BUDGET_MIN_ATTEMPTS=5
DMS_ERROR_BUDGET_MAX_FAILURE_RATE=0.5
DMS_ERROR_BUDGET_COOLDOWN_SECONDS=300

# Operation envelope payload limits (bytes)
MERLIN_OPERATION_PAYLOAD_MAX_BYTES=262144
# Optional per-operation overrides (comma-separated operation=max_bytes pairs)
# Example: assistant.chat.request=65536,merlin.rag.query=262144
MERLIN_OPERATION_PAYLOAD_MAX_BYTES_BY_OPERATION=
MERLIN_OPERATION_METRICS_MAX_SAMPLES=512
# Optional per-operation rate limit controls (requests per minute)
# 0 disables rate limiting.
MERLIN_OPERATION_RATE_LIMIT_PER_MINUTE=0
# Optional per-operation override pairs: operation=requests_per_minute
MERLIN_OPERATION_RATE_LIMIT_PER_MINUTE_BY_OPERATION=
# Optional operation rollout flags: operation=enabled|disabled
# Example: merlin.plugins.execute=disabled,merlin.research.manager.session.create=enabled
MERLIN_OPERATION_FEATURE_FLAGS=
# Local debug endpoint for idempotent replay cache diagnostics.
MERLIN_OPERATION_REPLAY_DIAGNOSTICS_ENABLED=false
# Endpoint-level dependency circuit breaker for unstable dependencies.
MERLIN_DEPENDENCY_CIRCUIT_BREAKER_ENABLED=true
MERLIN_DEPENDENCY_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
MERLIN_DEPENDENCY_CIRCUIT_BREAKER_RESET_SECONDS=30
# Plugin crash auto-restart budget (0 disables restart attempts).
MERLIN_PLUGIN_RESTART_MAX_ATTEMPTS=2
# Plugin execution mode: process (isolated, default) or thread (legacy in-process).
MERLIN_PLUGIN_EXECUTION_MODE=process
# Process worker pool size for plugin process mode.
MERLIN_PLUGIN_PROCESS_POOL_SIZE=2
# SQLite concurrency tuning (for merlin_db.py)
MERLIN_SQLITE_JOURNAL_MODE=WAL
MERLIN_SQLITE_SYNCHRONOUS=NORMAL
MERLIN_SQLITE_BUSY_TIMEOUT_MS=5000
MERLIN_SQLITE_WAL_AUTOCHECKPOINT=1000
MERLIN_SQLITE_CACHE_SIZE_KB=8192
MERLIN_SQLITE_TEMP_STORE=MEMORY

# Nemotron 3 configuration
NEMOTRON_API_KEY=
NEMOTRON_URL=http://localhost:8001/v1/chat/completions
NEMOTRON_MODEL=nemotron-3

# GLM configuration
GLM_API_KEY=
GLM_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4

# Nomic configuration
NOMIC_URL=http://localhost:11434/api/chat
NOMIC_MODEL=nomic-embed-text

# HuggingFace configuration
HF_API_URL=https://api-inference.huggingface.co/models/mistralai/Mistral-7B-Instruct-v0.2
HF_API_KEY=
MERLIN_LM_TIMEOUT=30
MERLIN_HF_TIMEOUT=60

# Backup automation
MERLIN_GDRIVE_CREDENTIALS=credentials.json
MERLIN_GDRIVE_TOKEN=token.pickle
MERLIN_GDRIVE_FOLDER_ID=
MERLIN_BACKUP_SCRIPT=merlin_backup_to_drive.py
MERLIN_BACKUP_HOUR=2
MERLIN_BACKUP_MINUTE=0
MERLIN_BACKUP_ON_START=false

# Launcher commands
MERLIN_BACKEND_CMD=
MERLIN_CLIENT_CMD=

# Config sync
MERLIN_SYNC_FOLDER=~/Dropbox/MerlinConfigSync

# Maintenance
MERLIN_LOG_RETENTION_DAYS=90
MERLIN_REMINDER_HOUR=9
MERLIN_REMINDER_MINUTE=0
MERLIN_REMINDER_MESSAGE=Time to check in with Merlin!
