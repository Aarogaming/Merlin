{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/aas.repo-capability-manifest.v1.schema.json",
  "title": "AAS Repo Capability Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "repo",
    "service",
    "capabilities"
  ],
  "properties": {
    "schema_name": {
      "const": "AAS.RepoCapabilityManifest"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "endpoint": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "version"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "stability": {
            "type": "string",
            "enum": [
              "experimental",
              "stable",
              "deprecated"
            ]
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
