{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/discovery/score_result.schema.json",
  "title": "AAS Discovery Score Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "item_id",
    "score",
    "confidence",
    "model_mode",
    "reason",
    "tags",
    "scored_at",
    "explainability"
  ],
  "properties": {
    "schema_name": {
      "const": "AAS.Discovery.ScoreResult"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "item_id": {
      "type": "string",
      "pattern": "^item_[A-Za-z0-9_-]{8,64}$"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "model_mode": {
      "type": "string",
      "enum": [
        "local",
        "null",
        "online",
        "stub"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "scored_at": {
      "type": "string",
      "format": "date-time"
    },
    "explainability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_trust",
        "relevance",
        "novelty"
      ],
      "properties": {
        "source_trust": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "relevance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "novelty": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
